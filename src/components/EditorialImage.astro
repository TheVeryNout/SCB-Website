---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  sizes?: string;
}

const {
  src,
  alt,
  class: className,
  sizes = "(min-width: 1024px) 32rem, 100vw",
} = Astro.props;
---

<div class:list={["overflow-hidden rounded-[2rem] border border-slate-900/10 bg-white/70", className]}>
  <Image
    src={src}
    alt={alt}
    sizes={sizes}
    widths={[480, 768, 1200]}
    class="h-full w-full object-cover"
  />
</div>
