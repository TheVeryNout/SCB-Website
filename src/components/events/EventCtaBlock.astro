---
import LinkButton from "../LinkButton.astro";
import type { EventOccurrence } from "../../lib/events/model";

interface Props {
  occurrence: EventOccurrence;
}

const { occurrence } = Astro.props;

const primaryHref = occurrence.registrationUrl ?? occurrence.ctaUrl;
const primaryLabel = occurrence.registrationUrl ? "Anmeldung oeffnen" : occurrence.ctaLabel;
---

{
  primaryHref || occurrence.instagramUrl ? (
    <div class="space-y-4">
      <div>
        <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Weiterfuehrende Links</p>
        <h2 class="mt-2 text-2xl font-semibold text-slate-950">Mehr zum Termin</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {
          primaryHref && primaryLabel ? (
            <LinkButton href={primaryHref} target="_blank" rel="noreferrer">
              {primaryLabel}
            </LinkButton>
          ) : null
        }
        {
          occurrence.instagramUrl ? (
            <LinkButton href={occurrence.instagramUrl} target="_blank" rel="noreferrer" variant="outline">
              Instagram pruefen
            </LinkButton>
          ) : null
        }
      </div>
    </div>
  ) : null
}
