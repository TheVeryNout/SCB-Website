---
import EventMeta from "./EventMeta.astro";
import EventStatusBadge from "./EventStatusBadge.astro";
import RecurringSeriesHint from "./RecurringSeriesHint.astro";
import type { EventOccurrence } from "../../lib/events/model";

interface Props {
  occurrence: EventOccurrence;
  showSummary?: boolean;
  compact?: boolean;
}

const { occurrence, showSummary = true, compact = false } = Astro.props;
---

<article class:list={["rounded-2xl border border-slate-200 bg-white/80", compact ? "p-4" : "p-5"]}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <EventMeta occurrence={occurrence} compact={compact} />
    <EventStatusBadge status={occurrence.status} />
  </div>
  <h3 class:list={["font-semibold text-slate-950", compact ? "mt-3 text-base" : "mt-3 text-lg"]}>
    <a class="hover:text-slate-700" href={occurrence.occurrencePath}>
      {occurrence.title}
    </a>
  </h3>
  {
    occurrence.isRecurring ? (
      <div class="mt-3">
        <RecurringSeriesHint isRecurring={occurrence.isRecurring} />
      </div>
    ) : null
  }
  {
    showSummary ? (
      <p class="mt-3 text-sm leading-6 text-slate-700">{occurrence.summary}</p>
    ) : null
  }
</article>
