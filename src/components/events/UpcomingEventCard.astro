---
import { formatGermanDate, formatGermanTimeRange } from "../../lib/events/engine";
import type { EventOccurrence } from "../../lib/events/model";

interface Props {
  occurrence: EventOccurrence;
  showSummary?: boolean;
}

const { occurrence, showSummary = true } = Astro.props;
---

<article class="rounded-2xl border border-slate-200 bg-white/80 p-4">
  <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">
    {formatGermanDate(occurrence.occurrenceDate)}
  </p>
  <h3 class="mt-2 text-lg font-semibold text-slate-950">
    <a class="hover:text-slate-700" href={occurrence.occurrencePath}>
      {occurrence.title}
    </a>
  </h3>
  <p class="mt-2 text-sm text-slate-700">
    {formatGermanTimeRange(occurrence.startTime, occurrence.endTime)} · {occurrence.locationName}
  </p>
  {
    occurrence.isRecurring ? (
      <p class="mt-2 text-xs font-semibold tracking-[0.16em] text-amber-700 uppercase">
        Wiederkehrender Termin
      </p>
    ) : null
  }
  {
    showSummary ? (
      <p class="mt-3 text-sm leading-6 text-slate-700">{occurrence.summary}</p>
    ) : null
  }
</article>
