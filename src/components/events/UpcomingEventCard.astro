---
import EventMeta from "./EventMeta.astro";
import EventStatusBadge from "./EventStatusBadge.astro";
import RecurringSeriesHint from "./RecurringSeriesHint.astro";
import type { EventOccurrence } from "../../lib/events/model";

interface Props {
  occurrence: EventOccurrence;
  showSummary?: boolean;
  compact?: boolean;
}

const { occurrence, showSummary = true, compact = false } = Astro.props;
---

<article class:list={["border border-[#414141]/25 bg-white", compact ? "p-4" : "p-5"]}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <EventMeta occurrence={occurrence} compact={compact} />
    <EventStatusBadge status={occurrence.status} />
  </div>
  <h3 class:list={["scb-display text-[#414141]", compact ? "mt-3 text-xl" : "mt-3 text-2xl"]}>
    <a class="hover:text-[#b14926]" href={occurrence.occurrencePath}>
      {occurrence.title}
    </a>
  </h3>
  {
    occurrence.isRecurring ? (
      <div class="mt-3">
        <RecurringSeriesHint isRecurring={occurrence.isRecurring} />
      </div>
    ) : null
  }
  {
    showSummary ? (
      <p class="mt-3 text-sm leading-6 text-[#414141]">{occurrence.summary}</p>
    ) : null
  }
</article>
