---
import type { EventStatus } from "../../lib/events/model";

interface Props {
  status: EventStatus;
}

const { status } = Astro.props;

const labels = {
  scheduled: "Geplant",
  cancelled: "Abgesagt",
  postponed: "Verschoben",
  tentative: "Vorlaeufig",
} as const;

const statusClasses = {
  scheduled: "border-[#414141] bg-[#ead871] text-[#414141]",
  cancelled: "border-[#b14926] bg-white text-[#b14926]",
  postponed: "border-[#414141] bg-[#f4eeb5] text-[#414141]",
  tentative: "border-[#414141] bg-white text-[#414141]",
} as const;
---

<span
  class:list={[
    "inline-flex items-center border px-3 py-1 text-xs font-semibold uppercase",
    statusClasses[status],
  ]}
>
  {labels[status]}
</span>
