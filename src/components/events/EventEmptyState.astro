---
interface Props {
  title?: string;
  message: string;
}

const { title = "Noch keine Termine", message } = Astro.props;
---

<div class="rounded-[1.5rem] border border-dashed border-slate-300 bg-white/70 p-5">
  <h3 class="text-lg font-semibold text-slate-950">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-slate-700">{message}</p>
</div>
