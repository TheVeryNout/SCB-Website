---
interface Props {
  title?: string;
  message: string;
}

const { title = "Noch keine Termine", message } = Astro.props;
---

<div class="border border-dashed border-[#414141]/45 bg-white/80 p-5">
  <h3 class="scb-display text-2xl text-[#414141]">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-[#414141]">{message}</p>
</div>
