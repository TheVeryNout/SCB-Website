---
import LinkButton from "../LinkButton.astro";
import type { EventOccurrence } from "../../lib/events/model";

interface Props {
  occurrence: EventOccurrence;
}

const { occurrence } = Astro.props;
---

<div class="space-y-3">
  <div>
    <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Ort</p>
    <h2 class="mt-2 text-2xl font-semibold text-slate-950">{occurrence.locationName}</h2>
  </div>
  {
    occurrence.address ? (
      <p class="text-sm leading-7 text-slate-700 whitespace-pre-line">
        {occurrence.address}
      </p>
    ) : null
  }
  {
    occurrence.mapUrl ? (
      <LinkButton href={occurrence.mapUrl} target="_blank" rel="noreferrer" variant="outline">
        Route in Karte oeffnen
      </LinkButton>
    ) : null
  }
</div>
