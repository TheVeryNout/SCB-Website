---
import Container from "./Container.astro";
import { getSiteSettingsEntry } from "../lib/content/site";

const settings = await getSiteSettingsEntry();
---

<footer class="border-t border-slate-900/10 bg-slate-950 text-slate-200">
  <Container class="flex flex-col gap-4 py-8 text-sm md:flex-row md:items-center md:justify-between">
    <div class="space-y-1">
      <p class="font-semibold text-white">{settings.data.organizationName}</p>
      <p class="max-w-xl text-slate-400">
        {settings.data.footerNote ?? settings.data.siteDescription}
      </p>
    </div>

    <div class="flex flex-wrap gap-4">
      {
        settings.data.socialLinks.map((link) => (
          <a
            class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white"
            href={link.url}
            rel="noreferrer"
            target="_blank"
          >
            {link.label}
          </a>
        ))
      }
      <a
        class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white"
        href={`mailto:${settings.data.contactEmail}`}
      >
        E-Mail
      </a>
      <a class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white" href="/impressum/">
        Impressum
      </a>
      <a class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white" href="/datenschutz/">
        Datenschutz
      </a>
      <a class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white" href="/admin/">
        CMS
      </a>
    </div>
  </Container>
</footer>
