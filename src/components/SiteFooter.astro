---
import Container from "./Container.astro";
---

<footer class="border-t border-slate-900/10 bg-slate-950 text-slate-200">
  <Container class="flex flex-col gap-4 py-8 text-sm md:flex-row md:items-center md:justify-between">
    <div class="space-y-1">
      <p class="font-semibold text-white">SCB Website Bootstrap</p>
      <p class="max-w-xl text-slate-400">
        Astro, Tailwind 4, and a Decap CMS shell are now wired in. Content collections and route implementation follow next.
      </p>
    </div>

    <div class="flex flex-wrap gap-4">
      <a class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white" href="/admin/">
        CMS
      </a>
      <a class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white" href="/impressum/">
        Impressum
      </a>
      <a class="text-slate-200 underline decoration-amber-400/70 underline-offset-4 hover:text-white" href="/datenschutz/">
        Datenschutz
      </a>
    </div>
  </Container>
</footer>

