---
interface Props {
  as?: "article" | "div" | "section";
  tone?: "default" | "warm" | "muted";
  padding?: "md" | "lg";
  class?: string;
}

const props = Astro.props as Props & Record<string, unknown>;

const {
  as: Tag = "div",
  tone = "default",
  padding = "lg",
  class: className,
  ...rest
} = props;

const toneClasses = {
  default: "border-[#414141]/35 bg-[#ead871]/92",
  warm: "border-[#414141]/35 bg-[#f4eeb5]/95",
  muted: "border-[#ead871]/35 bg-[#414141] text-[#ead871]",
} as const;

const paddingClasses = {
  md: "p-5 sm:p-6",
  lg: "p-6 sm:p-8",
} as const;
---

<Tag
  {...rest}
  class:list={[
    "border",
    toneClasses[tone],
    paddingClasses[padding],
    className,
  ]}
>
  <slot />
</Tag>
