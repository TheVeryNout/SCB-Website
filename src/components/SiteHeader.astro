---
import Container from "./Container.astro";
import crest from "../assets/images/wix-staging/shared/site/dfbc4d_0c5a0de8605c42cbbf4d5ebc30565f1e~mv2.png";
import { getSiteSettingsEntry } from "../lib/content/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const settings = await getSiteSettingsEntry();

const navItems = [
  { href: "/", label: "Start" },
  { href: "/neuigkeiten/", label: "Neuigkeiten" },
  { href: "/ueber-uns/", label: "Uber uns" },
  { href: "/pics-n-vids/", label: "Pics n Vids" },
  { href: "/veranstaltungen/", label: "Veranstaltungen" },
  { href: "/mitgliedschaft/", label: "Mitgliedschaft" },
  { href: "/kontakt/", label: "Kontakt" },
];
---

<header class="border-b border-[#181818] bg-[#333333] text-[#ead871]">
  <Container class="py-3">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div>
        <a class="inline-flex items-center gap-4 text-lg font-semibold text-[#ead871] uppercase no-underline" href="/">
          <img class="h-14 w-14 object-contain" src={crest.src} alt="" width="56" height="50" />
          <span class="sr-only">{settings.data.organizationName}</span>
        </a>
      </div>

      <nav aria-label="Primary" class="hidden flex-wrap justify-end gap-7 md:flex">
        {
          navItems.map((item) => {
            const isActive = currentPath === item.href;

            return (
              <a
                href={item.href}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "scb-display text-xl no-underline transition",
                  isActive
                    ? "text-[#b14926]"
                    : "text-[#ead871] hover:text-white",
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>

      <details class="group w-full md:hidden">
        <summary class="scb-display flex cursor-pointer list-none items-center justify-center border border-[#ead871] px-4 py-2 text-lg text-[#ead871]">
          Navigation
        </summary>
        <nav aria-label="Primary mobile" class="mt-4 grid gap-2">
          {
            navItems.map((item) => {
              const isActive = currentPath === item.href;

              return (
                <a
                  href={item.href}
                  aria-current={isActive ? "page" : undefined}
                  class:list={[
                    "scb-display border px-4 py-3 text-lg no-underline transition",
                    isActive
                      ? "border-[#b14926] text-[#b14926]"
                      : "border-[#ead871]/35 text-[#ead871] hover:border-white hover:text-white",
                  ]}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </details>
    </div>
  </Container>
</header>
