---
interface Props {
  href: string;
  variant?: "solid" | "outline" | "subtle";
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = "solid",
  class: className,
  target,
  rel,
} = Astro.props;

const variantClasses = {
  solid:
    "border-[#414141] bg-[#414141] text-[#ead871] hover:border-[#181818] hover:bg-[#181818] hover:text-white",
  outline:
    "border-[#414141] bg-transparent text-[#414141] hover:bg-[#414141] hover:text-[#ead871]",
  subtle:
    "border-[#ead871] bg-[#ead871] text-[#414141] hover:border-white hover:bg-white",
} as const;
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[
    "inline-flex items-center justify-center border px-6 py-3 text-sm font-semibold uppercase no-underline transition",
    variantClasses[variant],
    className,
  ]}
>
  <slot />
</a>
