---
interface Props {
  href: string;
  variant?: "solid" | "outline" | "subtle";
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = "solid",
  class: className,
  target,
  rel,
} = Astro.props;

const variantClasses = {
  solid:
    "border-slate-950 bg-slate-950 text-white hover:border-slate-800 hover:bg-slate-800",
  outline:
    "border-slate-950/20 bg-white/75 text-slate-950 hover:border-slate-950 hover:bg-slate-950 hover:text-white",
  subtle:
    "border-amber-500/30 bg-amber-100/80 text-slate-950 hover:border-amber-500 hover:bg-amber-200",
} as const;
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[
    "inline-flex items-center justify-center rounded-full border px-5 py-2.5 text-sm font-semibold no-underline transition",
    variantClasses[variant],
    className,
  ]}
>
  <slot />
</a>
