---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: "start" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  intro,
  align = "start",
  class: className,
} = Astro.props;

const isCentered = align === "center";
---

<div
  class:list={[
    "space-y-4",
    isCentered ? "mx-auto flex max-w-3xl flex-col items-center text-center" : "max-w-3xl",
    className,
  ]}
>
  {
    eyebrow ? (
      <p class="scb-display inline-flex border-b-4 border-[#414141] text-xl text-[#414141] uppercase">
        {eyebrow}
      </p>
    ) : null
  }
  <h1 class="scb-display text-5xl text-[#414141] uppercase sm:text-7xl">{title}</h1>
  {
    intro ? (
      <p class="text-lg leading-8 text-[#414141]">
        {intro}
      </p>
    ) : null
  }
  {Astro.slots.has("default") ? <div class="pt-2"><slot /></div> : null}
</div>
