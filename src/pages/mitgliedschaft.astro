---
import { render } from "astro:content";

import Container from "../components/Container.astro";
import EditorialImage from "../components/EditorialImage.astro";
import LinkButton from "../components/LinkButton.astro";
import PageIntro from "../components/PageIntro.astro";
import RichText from "../components/RichText.astro";
import SurfaceCard from "../components/SurfaceCard.astro";
import { getRequiredPageEntry, getSiteSettingsEntry } from "../lib/content/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const [settings, membershipPage] = await Promise.all([
  getSiteSettingsEntry(),
  getRequiredPageEntry("membership"),
]);

const { Content } = await render(membershipPage);
const benefits = membershipPage.data.benefits ?? [];
const applicationInstructions = membershipPage.data.applicationInstructions ?? [];
const notes = membershipPage.data.notes ?? [];
const hasBody = typeof membershipPage.body === "string" && membershipPage.body.trim().length > 0;
---

<BaseLayout
  title={`${membershipPage.data.title} | ${settings.data.organizationName}`}
  description={membershipPage.data.intro}
>
  <section class="scb-section py-16 sm:py-20">
    <Container class="space-y-10">
      <div class="grid gap-8 xl:grid-cols-[1.05fr_0.95fr] xl:items-start">
        <PageIntro
          eyebrow="Mitgliedschaft"
          title={membershipPage.data.title}
          intro={membershipPage.data.intro}
        >
          <div class="flex flex-wrap gap-3">
            <LinkButton href={membershipPage.data.membershipFormPdf!} target="_blank" rel="noreferrer">
              Mitgliedsantrag herunterladen
            </LinkButton>
            <LinkButton href="/kontakt/" variant="outline">
              Rueckfragen stellen
            </LinkButton>
          </div>
        </PageIntro>

        {
          membershipPage.data.heroImage ? (
            <EditorialImage
              src={membershipPage.data.heroImage}
              alt={`Bild zur ${membershipPage.data.title.toLowerCase()} beim ${settings.data.organizationName}`}
              class="min-h-[18rem] shadow-[0_20px_60px_-30px_rgba(15,23,42,0.35)]"
              sizes="(min-width: 1280px) 32rem, 100vw"
            />
          ) : (
            <SurfaceCard as="section" tone="warm" aria-labelledby="membership-download-heading">
              <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Mitmachen</p>
              <h2 id="membership-download-heading" class="mt-2 text-2xl font-semibold text-slate-950">
                Der Antrag bleibt bewusst einfach
              </h2>
              <p class="mt-3 text-sm leading-7 text-slate-700">
                Fuer den Start bleibt der offizielle PDF-Antrag das verbindliche Dokument. Die Seite erklaert nur den Weg dorthin und fuehrt direkt zur passenden Datei.
              </p>
            </SurfaceCard>
          )
        }
      </div>

      <div class="grid gap-5 xl:grid-cols-[1fr_0.92fr]">
        <SurfaceCard as="section" aria-labelledby="membership-benefits-heading">
          <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Warum mitmachen</p>
          <h2 id="membership-benefits-heading" class="mt-2 text-2xl font-semibold text-slate-950">
            Was Mitgliedschaft beim SCB traegt
          </h2>
          <ul class="mt-6 grid gap-3 sm:grid-cols-2">
            {
              benefits.map((benefit) => (
                <li class="border border-slate-200 bg-white/75 px-4 py-4 text-sm leading-6 text-slate-700">
                  {benefit}
                </li>
              ))
            }
          </ul>
        </SurfaceCard>

        <div class="grid gap-5">
          <SurfaceCard as="section" aria-labelledby="membership-steps-heading">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Antrag stellen</p>
            <h2 id="membership-steps-heading" class="mt-2 text-2xl font-semibold text-slate-950">
              So laeuft der Antrag
            </h2>
            <ol class="mt-6 space-y-3">
              {
                applicationInstructions.map((instruction, index) => (
                  <li class="flex gap-4 border border-slate-200 bg-white/75 p-4">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center border border-amber-500/40 bg-amber-100 text-sm font-semibold text-slate-950">
                      {index + 1}
                    </span>
                    <p class="pt-1 text-sm leading-6 text-slate-700">{instruction}</p>
                  </li>
                ))
              }
            </ol>
            <div class="mt-6">
              <LinkButton
                href={membershipPage.data.membershipFormPdf!}
                target="_blank"
                rel="noreferrer"
              >
                PDF jetzt herunterladen
              </LinkButton>
            </div>
          </SurfaceCard>

          {
            notes.length > 0 ? (
              <SurfaceCard as="section" tone="warm" aria-labelledby="membership-notes-heading">
                <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Hinweise</p>
                <h2 id="membership-notes-heading" class="mt-2 text-2xl font-semibold text-slate-950">
                  Wichtige Eckpunkte
                </h2>
                <ul class="mt-5 space-y-3">
                  {
                    notes.map((note) => (
                      <li class="border border-amber-500/25 bg-white/80 px-4 py-4 text-sm leading-6 text-slate-700">
                        {note}
                      </li>
                    ))
                  }
                </ul>
              </SurfaceCard>
            ) : null
          }
        </div>
      </div>

      {
        hasBody ? (
          <SurfaceCard as="section" aria-labelledby="membership-body-heading">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Mehr dazu</p>
            <h2 id="membership-body-heading" class="mt-2 text-2xl font-semibold text-slate-950">
              Einordnung
            </h2>
            <RichText class="mt-6">
              <Content />
            </RichText>
          </SurfaceCard>
        ) : null
      }
    </Container>
  </section>
</BaseLayout>
