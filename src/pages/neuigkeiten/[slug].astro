---
import { render } from "astro:content";

import Container from "../../components/Container.astro";
import EditorialImage from "../../components/EditorialImage.astro";
import LinkButton from "../../components/LinkButton.astro";
import PageIntro from "../../components/PageIntro.astro";
import RichText from "../../components/RichText.astro";
import SurfaceCard from "../../components/SurfaceCard.astro";
import { getAllPosts, getLatestPosts, getSiteSettingsEntry } from "../../lib/content/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => ({
    params: {
      slug: post.data.slug,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const settings = await getSiteSettingsEntry();
const { Content } = await render(post);
const relatedPosts = (await getLatestPosts(3)).filter((candidate) => candidate.data.slug !== post.data.slug).slice(0, 2);
const dateFormatter = new Intl.DateTimeFormat("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
---

<BaseLayout
  title={`${post.data.title} | ${settings.data.organizationName}`}
  description={post.data.excerpt}
>
  <section class="scb-section py-16 sm:py-20">
    <Container class="max-w-5xl space-y-8">
      <LinkButton href="/neuigkeiten/" variant="outline">
        Zurueck zu den Neuigkeiten
      </LinkButton>

      <SurfaceCard as="article" aria-labelledby="post-heading">
        <div class="space-y-6">
          <PageIntro title={post.data.title} intro={post.data.excerpt} class="max-w-none">
            <div class="flex flex-wrap gap-3">
              <span class="border border-slate-300 bg-white/75 px-4 py-2 text-sm text-slate-700">
                {dateFormatter.format(new Date(post.data.publishedAt))}
              </span>
              {
                post.data.category ? (
                  <span class="border border-amber-500/35 bg-amber-100/80 px-4 py-2 text-sm font-semibold text-slate-950">
                    {post.data.category}
                  </span>
                ) : null
              }
            </div>
          </PageIntro>

          {
            post.data.coverImage ? (
              <EditorialImage
                src={post.data.coverImage}
                alt={`Titelbild zum Beitrag ${post.data.title}`}
                class="min-h-[18rem]"
                sizes="(min-width: 1024px) 48rem, 100vw"
              />
            ) : null
          }

          <RichText>
            <Content />
          </RichText>
        </div>
      </SurfaceCard>

      {
        relatedPosts.length > 0 ? (
          <SurfaceCard as="section" aria-labelledby="related-posts-heading">
            <div class="flex flex-wrap items-end justify-between gap-4">
              <div>
                <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Weitere Beitraege</p>
                <h2 id="related-posts-heading" class="mt-2 text-2xl font-semibold text-slate-950">
                  Weitere aktuelle Meldungen
                </h2>
              </div>
            </div>
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {
                relatedPosts.map((relatedPost) => (
                  <article class="border border-slate-200 bg-white/75 p-5">
                    <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
                      {dateFormatter.format(new Date(relatedPost.data.publishedAt))}
                    </p>
                    <h3 class="mt-2 text-lg font-semibold text-slate-950">
                      <a class="no-underline hover:underline" href={`/neuigkeiten/${relatedPost.data.slug}/`}>
                        {relatedPost.data.title}
                      </a>
                    </h3>
                    <p class="mt-3 text-sm leading-6 text-slate-700">{relatedPost.data.excerpt}</p>
                  </article>
                ))
              }
            </div>
          </SurfaceCard>
        ) : null
      }
    </Container>
  </section>
</BaseLayout>
