---
import Container from "../../components/Container.astro";
import LinkButton from "../../components/LinkButton.astro";
import PageIntro from "../../components/PageIntro.astro";
import SurfaceCard from "../../components/SurfaceCard.astro";
import EventMonthOverview from "../../components/events/EventMonthOverview.astro";
import UpcomingEventsList from "../../components/events/UpcomingEventsList.astro";
import { getUpcomingOccurrences, getSiteSettingsEntry } from "../../lib/content/site";
import { groupOccurrencesByMonth } from "../../lib/events/engine";
import BaseLayout from "../../layouts/BaseLayout.astro";

const EVENT_PAGE_OPTIONS = {
  horizonPastMonths: 0,
  horizonFutureMonths: 4,
} as const;

const [settings, allUpcomingOccurrences] = await Promise.all([
  getSiteSettingsEntry(),
  getUpcomingOccurrences(undefined, EVENT_PAGE_OPTIONS),
]);

const upcomingOccurrences = allUpcomingOccurrences.slice(0, 6);
const monthGroups = groupOccurrencesByMonth(allUpcomingOccurrences);
const weatherSensitiveOccurrence = allUpcomingOccurrences.find((occurrence) => occurrence.weatherNote);
---

<BaseLayout
  title={`Veranstaltungen | ${settings.data.organizationName}`}
  description="Oeffentliche Termine des Skate Club Biriciana e.V. mit naechsten Sessions und Monatsueberblick."
>
  <section class="scb-section py-16 sm:py-20">
    <Container class="space-y-10">
      <PageIntro
        eyebrow="Veranstaltungen"
        title="Oeffentliche Termine und wiederkehrende Sessions"
        intro="Hier laufen die naechsten oeffentlichen SCB-Termine zusammen. Auf dem Handy bleibt die naechste Liste die schnellste Orientierung, darunter folgt der Monatsueberblick."
      >
        <div class="flex flex-wrap gap-3">
          <LinkButton href={`mailto:${settings.data.contactEmail}`} variant="outline">
            Frage zum Termin stellen
          </LinkButton>
        </div>
      </PageIntro>

      <div class="grid gap-5 xl:grid-cols-[1fr_1.1fr]">
        <SurfaceCard as="section" aria-labelledby="upcoming-events-heading">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Naechste Termine</p>
              <h2 id="upcoming-events-heading" class="mt-2 text-2xl font-semibold text-slate-950">
                Was als Naechstes ansteht
              </h2>
            </div>
            <p class="text-sm text-slate-600">
              {allUpcomingOccurrences.length} oeffentliche Termin{allUpcomingOccurrences.length === 1 ? "" : "e"} im sichtbaren Zeitraum
            </p>
          </div>
          <UpcomingEventsList occurrences={upcomingOccurrences} />
        </SurfaceCard>

        <SurfaceCard as="section" tone="warm" aria-labelledby="calendar-note-heading">
          <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Hinweis</p>
          <h2 id="calendar-note-heading" class="mt-2 text-2xl font-semibold text-slate-950">
            Der Kalender bleibt bewusst schlicht
          </h2>
          <p class="mt-3 text-sm leading-7 text-slate-700">
            Einzeltermine und wiederkehrende Serien kommen aus demselben Website-eigenen Eventmodell. So bleibt die Pflege fuer den Verein einfach und die oeffentlichen Termine werden komplett statisch gebaut.
          </p>
          {
            weatherSensitiveOccurrence?.weatherNote ? (
              <div class="mt-5 border border-amber-500/25 bg-white/75 p-4">
                <p class="text-xs font-semibold tracking-[0.16em] text-amber-700 uppercase">
                  Wetterabhaengig
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-700">
                  {weatherSensitiveOccurrence.weatherNote}
                </p>
              </div>
            ) : null
          }
        </SurfaceCard>
      </div>

      <SurfaceCard as="section" aria-labelledby="month-overview-heading">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Monatsueberblick</p>
            <h2 id="month-overview-heading" class="mt-2 text-2xl font-semibold text-slate-950">
              Die naechsten Monate im Blick
            </h2>
          </div>
          <p class="max-w-xl text-sm leading-6 text-slate-600">
            Der Monatsueberblick bleibt absichtlich sekundar. Die Karten verlinken auf die konkrete Terminseite der jeweiligen Vorkommnis.
          </p>
        </div>
        <div class="mt-6">
          <EventMonthOverview monthGroups={monthGroups} />
        </div>
      </SurfaceCard>
    </Container>
  </section>
</BaseLayout>
