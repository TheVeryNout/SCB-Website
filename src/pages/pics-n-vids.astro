---
import Container from "../components/Container.astro";
import EditorialImage from "../components/EditorialImage.astro";
import LinkButton from "../components/LinkButton.astro";
import PageIntro from "../components/PageIntro.astro";
import SurfaceCard from "../components/SurfaceCard.astro";
import { getAllMedia, getSiteSettingsEntry } from "../lib/content/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const [settings, mediaEntries] = await Promise.all([
  getSiteSettingsEntry(),
  getAllMedia(),
]);

const videoEntries = mediaEntries.filter((entry) => entry.data.youtubeUrl);
const galleryEntries = mediaEntries.filter((entry) => entry.data.gallery?.length);
const featuredGallery = galleryEntries[0];
---

<BaseLayout
  title={`Pics n Vids | ${settings.data.organizationName}`}
  description="Einfache Medienseite mit Video-Links und kuratierten Eindruecken aus dem Vereinsumfeld."
>
  <section class="scb-section py-16 sm:py-20">
    <Container class="space-y-10">
      <PageIntro
        eyebrow="Pics n Vids"
        title="Clips, Rueckblicke und kuratierte Medien"
        intro="Die Medienseite bleibt bewusst leichtgewichtig: sichtbare Titel, klare externe Ziele und nur so viel Bildmaterial, wie fuer den oeffentlichen Vereinsauftritt sinnvoll ist."
      />

      <div class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
        <SurfaceCard as="section" aria-labelledby="media-videos-heading">
          <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Videos</p>
          <h2 id="media-videos-heading" class="mt-2 text-2xl font-semibold text-slate-950">
            Oeffentliche Videoziele
          </h2>

          <div class="mt-6 grid gap-4">
            {
              videoEntries.map((entry) => (
                <article class="border border-slate-200 bg-white/75 p-5">
                  <div class="grid gap-4 sm:grid-cols-[9rem_1fr] sm:items-start">
                    {
                      entry.data.thumbnailImage ? (
                        <EditorialImage
                          src={entry.data.thumbnailImage}
                          alt={`Vorschaubild fuer ${entry.data.title}`}
                          class="min-h-[8rem]"
                          sizes="9rem"
                        />
                      ) : null
                    }

                    <div class="space-y-3">
                      <div>
                        <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
                          {entry.data.type === "youtube" ? "YouTube" : "Medieneintrag"}
                        </p>
                        <h3 class="mt-2 text-lg font-semibold text-slate-950">{entry.data.title}</h3>
                        {
                          entry.data.summary ? (
                            <p class="mt-3 text-sm leading-6 text-slate-700">{entry.data.summary}</p>
                          ) : null
                        }
                      </div>

                      {
                        entry.data.youtubeUrl ? (
                          <LinkButton href={entry.data.youtubeUrl} target="_blank" rel="noreferrer" variant="outline">
                            Ziel oeffnen
                          </LinkButton>
                        ) : null
                      }
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </SurfaceCard>

        <div class="grid gap-5">
          <SurfaceCard as="section" tone="warm" aria-labelledby="media-note-heading">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Hinweis</p>
            <h2 id="media-note-heading" class="mt-2 text-2xl font-semibold text-slate-950">
              Keine schwere Galerieplattform
            </h2>
            <p class="mt-3 text-sm leading-7 text-slate-700">
              Fuer den Launch bleibt die Medienseite editorial und statisch. Sichtbare Titel und kuratierte Bilder reichen hier aus, statt ein komplexes Video- oder Galerie-System nachzubauen.
            </p>
          </SurfaceCard>

          {
            galleryEntries.length > 0 ? (
              <SurfaceCard as="section" aria-labelledby="media-gallery-heading">
                <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Bilder</p>
                <h2 id="media-gallery-heading" class="mt-2 text-2xl font-semibold text-slate-950">
                  Kuratierte Eindruecke
                </h2>
                <div class="mt-6 grid gap-5">
                  <div class="grid gap-4 sm:grid-cols-2">
                    {
                      featuredGallery?.data.gallery?.slice(0, 4).map((image, index) => (
                        <EditorialImage
                          src={image}
                          alt={`Medienbild ${index + 1} aus dem Umfeld von ${settings.data.organizationName}`}
                          class="min-h-[10rem]"
                          sizes="(min-width: 640px) 14rem, 100vw"
                        />
                      ))
                    }
                  </div>

                  <div class="grid gap-4">
                    {
                      galleryEntries.map((entry) => (
                        <article class="border border-slate-200 bg-white/75 p-5">
                          <div class="grid gap-4 sm:grid-cols-[9rem_1fr] sm:items-start">
                            {
                              entry.data.thumbnailImage ? (
                                <EditorialImage
                                  src={entry.data.thumbnailImage}
                                  alt={`Vorschaubild fuer ${entry.data.title}`}
                                  class="min-h-[8rem]"
                                  sizes="9rem"
                                />
                              ) : null
                            }

                            <div class="space-y-3">
                              <div>
                                <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
                                  Fotogalerie
                                </p>
                                <h3 class="mt-2 text-lg font-semibold text-slate-950">{entry.data.title}</h3>
                                {
                                  entry.data.summary ? (
                                    <p class="mt-3 text-sm leading-6 text-slate-700">{entry.data.summary}</p>
                                  ) : null
                                }
                              </div>

                              {
                                entry.data.gallery?.length ? (
                                  <p class="text-xs font-medium tracking-[0.14em] text-slate-500 uppercase">
                                    {entry.data.gallery.length} lokale Bilder migriert
                                  </p>
                                ) : null
                              }
                            </div>
                          </div>
                        </article>
                      ))
                    }
                  </div>
                </div>
              </SurfaceCard>
            ) : null
          }
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
