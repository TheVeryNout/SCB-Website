<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>SCB CMS</title>
    <style>
      :root {
        color-scheme: light;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: linear-gradient(180deg, #f8f5ec 0%, #fffdf8 100%);
        font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      }
    </style>
  </head>
  <body>
    <noscript>Decap CMS requires JavaScript.</noscript>
    <div id="cms-status" style="padding: 1rem; font-family: sans-serif;">CMS wird geladen...</div>

    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      const identityTokenPattern =
        /^#(confirmation_token|invite_token|recovery_token|access_token|error)=/;
      const hasIdentityToken = identityTokenPattern.test(window.location.hash);
      const statusNode = document.getElementById("cms-status");

      function loadCms() {
        if (document.querySelector("script[data-decap-cms]")) {
          return;
        }

        if (statusNode) {
          statusNode.textContent = "CMS wird geladen...";
        }

        const script = document.createElement("script");
        script.src = "https://unpkg.com/decap-cms@^3.11.0/dist/decap-cms.js";
        script.dataset.decapCms = "true";
        document.body.appendChild(script);
      }

      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function (user) {
          if (hasIdentityToken && !user) {
            if (statusNode) {
              statusNode.textContent = "Bitte schliesse die Anmeldung ab.";
            }
            window.netlifyIdentity.open();
            return;
          }

          if (!user) {
            window.netlifyIdentity.on("login", function () {
              window.location.href = "/admin/";
            });
          }

          loadCms();
        });

        window.netlifyIdentity.on("login", function () {
          window.location.href = "/admin/";
        });

        window.netlifyIdentity.on("close", function () {
          if (hasIdentityToken && !window.netlifyIdentity.currentUser()) {
            if (statusNode) {
              statusNode.textContent = "Anmeldung abgebrochen. Lade die Seite neu, um es erneut zu versuchen.";
            }
            return;
          }

          loadCms();
        });
      } else {
        loadCms();
      }
    </script>
  </body>
</html>
