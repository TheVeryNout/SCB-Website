---
import Container from "../components/Container.astro";
import EditorialImage from "../components/EditorialImage.astro";
import LinkButton from "../components/LinkButton.astro";
import PageIntro from "../components/PageIntro.astro";
import RichText from "../components/RichText.astro";
import SurfaceCard from "../components/SurfaceCard.astro";
import UpcomingEventsList from "../components/events/UpcomingEventsList.astro";
import {
  getHomepageEntry,
  getLatestPosts,
  getSiteSettingsEntry,
  getUpcomingOccurrences,
  validateSiteContent,
} from "../lib/content/site";
import BaseLayout from "../layouts/BaseLayout.astro";

await validateSiteContent();

const [homepage, settings, latestPosts, upcomingEvents] = await Promise.all([
  getHomepageEntry(),
  getSiteSettingsEntry(),
  getLatestPosts(3),
  getUpcomingOccurrences(3),
]);
---

<BaseLayout
  title={`${homepage.data.title} | ${settings.data.organizationName}`}
  description={settings.data.siteDescription}
>
  <section class="py-16 sm:py-24">
    <Container>
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div class="space-y-6">
          <PageIntro eyebrow="Start" title={homepage.data.heroTitle} intro={homepage.data.heroIntro}>
            <div class="flex flex-wrap gap-3">
              <LinkButton href="/veranstaltungen/">Zu den Terminen</LinkButton>
              <LinkButton href="/kontakt/" variant="outline">
                Kontakt aufnehmen
              </LinkButton>
            </div>
          </PageIntro>

          {
            homepage.data.featuredAnnouncement ? (
              <SurfaceCard tone="warm">
                <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">
                  Hinweis
                </p>
                <h2 class="mt-2 text-2xl font-semibold text-slate-950">
                  {homepage.data.featuredAnnouncement.title}
                </h2>
                <RichText class="mt-3">
                  <p>{homepage.data.featuredAnnouncement.body}</p>
                </RichText>
                {
                  homepage.data.featuredAnnouncement.linkUrl &&
                  homepage.data.featuredAnnouncement.linkLabel ? (
                    <div class="mt-5">
                      <LinkButton href={homepage.data.featuredAnnouncement.linkUrl} variant="outline">
                        {homepage.data.featuredAnnouncement.linkLabel}
                      </LinkButton>
                    </div>
                  ) : null
                }
              </SurfaceCard>
            ) : null
          }
        </div>

        <div class="grid gap-5">
          {
            homepage.data.heroImage ? (
              <EditorialImage
                src={homepage.data.heroImage}
                alt="Eindruecke aus dem Skatepark-Weissenburg-Umfeld des SCB"
                class="min-h-[18rem] shadow-[0_20px_60px_-30px_rgba(15,23,42,0.35)]"
              />
            ) : null
          }
          <SurfaceCard>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">
                  Naechste Termine
                </p>
                <h2 class="mt-2 text-2xl font-semibold text-slate-950">Was demnaechst ansteht</h2>
              </div>
              <span class="inline-flex items-center rounded-full border border-slate-300 bg-white/75 px-4 py-2 text-sm text-slate-700">
                {settings.data.contactEmail}
              </span>
            </div>
            <UpcomingEventsList occurrences={upcomingEvents} />
          </SurfaceCard>
        </div>
      </div>
    </Container>
  </section>

  <section class="pb-16 sm:pb-24">
    <Container>
      <div class="grid gap-5 md:grid-cols-[1.2fr_0.8fr]">
        <SurfaceCard as="article">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Neuigkeiten</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-950">Aktuelle Beiträge</h2>
            </div>
            <LinkButton href="/neuigkeiten/" variant="outline" class="px-4 py-2">
              Alle Beitraege
            </LinkButton>
          </div>
          <div class="mt-6 space-y-5">
            {
              latestPosts.map((post) => (
                <article class="rounded-2xl border border-slate-200 bg-white p-5">
                  <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
                    {new Intl.DateTimeFormat("de-DE", {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    }).format(new Date(post.data.publishedAt))}
                  </p>
                  <h3 class="mt-2 text-lg font-semibold text-slate-950">{post.data.title}</h3>
                  <p class="mt-3 text-sm leading-6 text-slate-700">{post.data.excerpt}</p>
                </article>
              ))
            }
          </div>
        </SurfaceCard>

        <div class="grid gap-5">
          <SurfaceCard as="article">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Mitgliedschaft</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950">
              {homepage.data.membershipCtaTitle ?? "Mitglied werden beim SCB"}
            </h2>
            <p class="mt-3 text-sm leading-6 text-slate-700">
              {homepage.data.membershipCtaText}
            </p>
            <LinkButton class="mt-5" href="/mitgliedschaft/" variant="outline">
              {homepage.data.membershipCtaLabel ?? "Zur Mitgliedschaft"}
            </LinkButton>
          </SurfaceCard>

          <SurfaceCard as="article">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Medien</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950">
              {homepage.data.mediaTeaserTitle ?? "Pics n Vids"}
            </h2>
            <p class="mt-3 text-sm leading-6 text-slate-700">
              {homepage.data.mediaTeaserText}
            </p>
            <LinkButton class="mt-5" href="/pics-n-vids/" variant="outline">
              Zur Medienseite
            </LinkButton>
          </SurfaceCard>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
