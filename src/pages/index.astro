---
import Container from "../components/Container.astro";
import {
  getHomepageEntry,
  getLatestPosts,
  getSiteSettingsEntry,
  getUpcomingOccurrences,
  validateSiteContent,
} from "../lib/content/site";
import { formatGermanDate, formatGermanTimeRange } from "../lib/events/engine";
import BaseLayout from "../layouts/BaseLayout.astro";

await validateSiteContent();

const [homepage, settings, latestPosts, upcomingEvents] = await Promise.all([
  getHomepageEntry(),
  getSiteSettingsEntry(),
  getLatestPosts(3),
  getUpcomingOccurrences(3),
]);
---

<BaseLayout
  title={`${homepage.data.title} | ${settings.data.organizationName}`}
  description={settings.data.siteDescription}
>
  <section class="py-16 sm:py-24">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1.3fr_0.9fr] lg:items-start">
        <div class="space-y-8">
          <div class="space-y-5">
            <p class="inline-flex rounded-full border border-amber-500/40 bg-amber-100 px-4 py-2 text-xs font-semibold tracking-[0.2em] text-slate-950 uppercase">
              Start
            </p>
            <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
              {homepage.data.heroTitle}
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-slate-700">
              {homepage.data.heroIntro}
            </p>
          </div>

          <div class="flex flex-wrap gap-4">
            <a class="inline-flex items-center justify-center rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white no-underline transition hover:bg-slate-800" href="/kontakt/">
              Kontakt aufnehmen
            </a>
            <span class="inline-flex items-center rounded-full border border-slate-300 bg-white/75 px-5 py-3 text-sm text-slate-700">
              {settings.data.contactEmail}
            </span>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-900/10 bg-white/80 p-6 shadow-[0_20px_60px_-30px_rgba(15,23,42,0.35)] backdrop-blur">
          <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Nächste Termine</p>
          {
            upcomingEvents.length > 0 ? (
              <ul class="mt-5 space-y-4">
                {
                  upcomingEvents.map((occurrence) => (
                    <li class="rounded-2xl border border-slate-200 bg-white/80 p-4">
                      <p class="text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">
                        {formatGermanDate(occurrence.occurrenceDate)}
                      </p>
                      <h2 class="mt-2 text-lg font-semibold text-slate-950">{occurrence.title}</h2>
                      <p class="mt-2 text-sm text-slate-700">
                        {formatGermanTimeRange(occurrence.startTime, occurrence.endTime)} · {occurrence.locationName}
                      </p>
                      <p class="mt-3 text-sm leading-6 text-slate-700">{occurrence.summary}</p>
                    </li>
                  ))
                }
              </ul>
            ) : (
              <p class="mt-5 text-sm leading-6 text-slate-700">
                Aktuell sind keine öffentlichen Termine im Voraus eingetragen.
              </p>
            )
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="pb-16 sm:pb-24">
    <Container>
      <div class="grid gap-5 md:grid-cols-[1.2fr_0.8fr]">
        <article class="rounded-[1.75rem] border border-slate-900/10 bg-white/85 p-6 shadow-[0_18px_45px_-35px_rgba(15,23,42,0.4)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Neuigkeiten</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-950">Aktuelle Beiträge</h2>
            </div>
            <a class="text-sm font-semibold text-slate-950 underline decoration-amber-400/70 underline-offset-4" href="/neuigkeiten/">
              Alle Beiträge
            </a>
          </div>
          <div class="mt-6 space-y-5">
            {
              latestPosts.map((post) => (
                <article class="rounded-2xl border border-slate-200 bg-white p-5">
                  <p class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
                    {new Intl.DateTimeFormat("de-DE", {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    }).format(new Date(post.data.publishedAt))}
                  </p>
                  <h3 class="mt-2 text-lg font-semibold text-slate-950">{post.data.title}</h3>
                  <p class="mt-3 text-sm leading-6 text-slate-700">{post.data.excerpt}</p>
                </article>
              ))
            }
          </div>
        </article>

        <div class="grid gap-5">
          <article class="rounded-[1.75rem] border border-slate-900/10 bg-white/85 p-6 shadow-[0_18px_45px_-35px_rgba(15,23,42,0.4)]">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Mitgliedschaft</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950">
              {homepage.data.membershipCtaTitle ?? "Mitglied werden beim SCB"}
            </h2>
            <p class="mt-3 text-sm leading-6 text-slate-700">
              {homepage.data.membershipCtaText}
            </p>
            <a
              class="mt-5 inline-flex items-center justify-center rounded-full border border-slate-950 px-5 py-2.5 text-sm font-semibold text-slate-950 no-underline transition hover:bg-slate-950 hover:text-white"
              href="/mitgliedschaft/"
            >
              {homepage.data.membershipCtaLabel ?? "Zur Mitgliedschaft"}
            </a>
          </article>

          <article class="rounded-[1.75rem] border border-slate-900/10 bg-white/85 p-6 shadow-[0_18px_45px_-35px_rgba(15,23,42,0.4)]">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">Medien</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950">
              {homepage.data.mediaTeaserTitle ?? "Pics n Vids"}
            </h2>
            <p class="mt-3 text-sm leading-6 text-slate-700">
              {homepage.data.mediaTeaserText}
            </p>
            <a
              class="mt-5 inline-flex items-center justify-center rounded-full border border-slate-950 px-5 py-2.5 text-sm font-semibold text-slate-950 no-underline transition hover:bg-slate-950 hover:text-white"
              href="/pics-n-vids/"
            >
              Zur Medienseite
            </a>
          </article>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
